# Copy to web/.env.local. These are exposed to the browser (NEXT_PUBLIC_*),
# so only the Supabase anon key belongs here — never the service role / JWT secret.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
