# ──────────────────────────────────────────────────────────────────────────
# AI Inbox Triage + Reply Router — environment template
# Copy to `.env` and fill in. Never commit the real `.env`.
# ──────────────────────────────────────────────────────────────────────────

# --- Core ---
APP_ENV=development                       # development | staging | production
LOG_LEVEL=INFO

# --- Database (Docker Postgres + pgvector) ---
# Inside docker-compose the host is `postgres`; from your host machine use localhost.
POSTGRES_USER=triage
POSTGRES_PASSWORD=triage_dev_pw
POSTGRES_DB=triage
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Full URL used by the backend (async + sync drivers share the same DSN base).
DATABASE_URL=postgresql://triage:triage_dev_pw@postgres:5432/triage

# --- Redis (queue / cache) ---
REDIS_URL=redis://redis:6379/0

# --- Auth: Supabase (identity provider only; app data lives in our Postgres) ---
# From Supabase project → Settings → API.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Settings → API → JWT Settings → JWT Secret. Used to verify access tokens.
SUPABASE_JWT_SECRET=your-jwt-secret

# --- LLM provider (Groq free tier by default; wrapper is pluggable) ---
LLM_PROVIDER=groq                          # groq | openai | anthropic
GROQ_API_KEY=your-groq-key
LLM_MODEL_FAST=llama-3.1-8b-instant        # cheap/fast: classification
LLM_MODEL_SMART=llama-3.3-70b-versatile    # higher quality: drafting
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3

# --- Embeddings (for RAG / pgvector) ---
# hash = free, offline, zero-setup default (lexical). fastembed = free local
# semantic model (pip install fastembed). openai = needs OPENAI_API_KEY.
EMBEDDING_PROVIDER=hash
EMBEDDING_DIM=384                          # 384 for hash/fastembed; 1536 for openai
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5     # used if EMBEDDING_PROVIDER=fastembed
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=
# RAG tuning
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RAG_TOP_K=5

# --- Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
SENTRY_DSN=

# --- Mailbox OAuth (Module 2 — placeholders for now) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/accounts/connect/google/callback
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_TENANT_ID=common

# Shared secret for the inbound mail webhook (sent as X-Webhook-Secret header).
MAIL_WEBHOOK_SECRET=

# --- Routing (Module 6) ---
# Optional Slack Incoming Webhook for routing notifications (free to create).
SLACK_WEBHOOK_URL=

# --- Token encryption (email_accounts.oauth_tokens at rest) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# --- Frontend (Next.js) — these are also read from web/.env.local ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
